					<v8:content>План</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Факт</dataPath>
			<field>Факт</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Факт</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Отклонение</dataPath>
			<field>Отклонение</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Отклонение</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ГрафикОтпусков.Сотрудник КАК Сотрудник,
	РАЗНОСТЬДАТ(ГрафикОтпусков.ДатаНачала, ГрафикОтпусков.ДатаОкончания, ДЕНЬ) + 1 КАК План,
	0 КАК Факт
ПОМЕСТИТЬ ВТ_ПланФакт
ИЗ
	Документ.ВКМ_ГрафикОтпусков.ОтпускаСотрудников КАК ГрафикОтпусков
ГДЕ
	ГрафикОтпусков.Ссылка.Проведен = ИСТИНА
	И ГрафикОтпусков.Ссылка.Год = ГОД(&amp;Год)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	НачисленияЗарплаты.Сотрудник,
	0,
	РАЗНОСТЬДАТ(ВЫБОР
			КОГДА НачисленияЗарплаты.ДатаНачала &lt; НАЧАЛОПЕРИОДА(&amp;Год, ГОД)
				ТОГДА НАЧАЛОПЕРИОДА(&amp;Год, ГОД)
			ИНАЧЕ НачисленияЗарплаты.ДатаНачала
		КОНЕЦ, ВЫБОР
			КОГДА НачисленияЗарплаты.ДатаОкончания &gt; КОНЕЦПЕРИОДА(&amp;Год, ГОД)
				ТОГДА КОНЕЦПЕРИОДА(&amp;Год, ГОД)
			ИНАЧЕ НачисленияЗарплаты.ДатаОкончания
		КОНЕЦ, ДЕНЬ) + 1
ИЗ
	Документ.ВКМ_НачисленияЗарплаты.Начисления КАК НачисленияЗарплаты
ГДЕ
	НачисленияЗарплаты.Ссылка.Проведен = ИСТИНА
	И НачисленияЗарплаты.ВидРасчета = &amp;ВидРасчетаОтпуск
	И НачисленияЗарплаты.ДатаНачала &lt;= КОНЕЦПЕРИОДА(&amp;Год, ГОД)
	И НачисленияЗарплаты.ДатаОкончания &gt;= НАЧАЛОПЕРИОДА(&amp;Год, ГОД)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ПланФакт.Сотрудник КАК Сотрудник,
	СУММА(ВТ_ПланФакт.План) КАК План,
	СУММА(ВТ_ПланФакт.Факт) КАК Факт,
	СУММА(ВТ_ПланФакт.Факт) - СУММА(ВТ_ПланФакт.План) КАК Отклонение
ИЗ
	ВТ_ПланФакт КАК ВТ_ПланФакт

СГРУППИРОВАТЬ ПО
	ВТ_ПланФакт.Сотрудник</query>
	</dataSet>
