#Область ПрограммныйИнтерфейс

Процедура ВыполнитьСоздание(Параметры, АдресРезультата) Экспорт
	
	Период = Параметры.Период; 
	МассивДоговоров = Параметры.МассивДоговоров;
	
	Для Каждого ТекДоговор Из МассивДоговоров Цикл
		
		// 1. Повторная проверка: вдруг кто-то уже создал документ, пока мы думали
		Если СуществуетДокументЗаПериод(ТекДоговор, Период) Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			// 2. Создание нового документа
			НовыйДокумент = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
			НовыйДокумент.Дата = КонецМесяца(Период); // Обычно акты делают концом месяца
			
			// 3. Стандартное заполнение (Заполнение шапки)
			ДанныеЗаполнения = Новый Структура("Договор", ТекДоговор);
			НовыйДокумент.Заполнить(ДанныеЗаполнения);
			
			// Явное присвоение, если стандартное заполнение не справилось с шапкой
			НовыйДокумент.Договор = ТекДоговор;
			НовыйДокумент.Контрагент = ТекДоговор.Владелец; // Владелец договора - это контрагент
			НовыйДокумент.Организация = ТекДоговор.Организация;
			
			// 4. Метод модуля объекта: ВыполнитьАвтозаполнение (из задания)
			НовыйДокумент.ВыполнитьАвтозаполнение();
			
			// 5. Проверка заполнения (Стандартный механизм)
			Если НЕ НовыйДокумент.ПроверитьЗаполнение() Тогда
				// Если есть ошибки заполнения, документ записываем непроведенным
				НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
			Иначе
				// 6. Проведение
				НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
		Исключение
			// Логируем ошибку в Журнал Регистрации, чтобы фоновое задание не падало целиком
			ЗаписьЖурналаРегистрации("ВКМ_МассовоеСоздание", УровеньЖурналаРегистрации.Ошибка, , ТекДоговор, ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Функция проверяет, есть ли уже Реализация по этому договору в указанном месяце
Функция СуществуетДокументЗаПериод(Договор, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Договор = &Договор
		|	И РеализацияТоваровУслуг.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Период));
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Период));
	
	Результат = Запрос.Выполнить();
	
	// Если запрос вернул хотя бы одну строку, значит документ уже есть
	Возврат НЕ Результат.Пустой();
	
КонецФункции

#КонецОбласти