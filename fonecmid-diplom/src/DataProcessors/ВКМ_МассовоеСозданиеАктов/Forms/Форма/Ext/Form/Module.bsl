&НаКлиенте
Перем АдресЗадания; // Переменная модуля формы для хранения адреса ID задания

&НаКлиенте
Процедура Заполнить(Команда) 
	
	ЗаполнитьНаСервере();   
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	// Очищаем таблицу перед заполнением
	Объект.СписокДоговоров.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Договоры.Ссылка КАК Договор,
		|	ЕСТЬNULL(Реализации.Ссылка, ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)) КАК Реализация
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК Договоры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализации
		|		ПО (Реализации.Договор = Договоры.Ссылка)
		|			И (НАЧАЛОПЕРИОДА(Реализации.Дата, МЕСЯЦ) = НАЧАЛОПЕРИОДА(&Период, МЕСЯЦ))
		|			И (НЕ Реализации.ПометкаУдаления)
		|ГДЕ
		|	Договоры.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание)
		|	И НЕ Договоры.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Период", Объект.Период);
	
		Объект.СписокДоговоров.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.СписокДоговоров.Добавить();
		НоваяСтрока.ТЧ_Договор = Выборка.Договор;
		НоваяСтрока.ТЧ_Реализация = Выборка.Реализация;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументы(Команда)
	
Если Объект.СписокДоговоров.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Список договоров пуст!");
		Возврат;
	КонецЕсли;
	
	// Подготовка параметров для передачи в фоновое задание
	ПараметрыЗадания = Новый Структура;
	ПараметрыЗадания.Вставить("Период", Объект.Период);
	
	МассивДоговоров = Новый Массив;
	Для Каждого Стр Из Объект.СписокДоговоров Цикл
		
		// ИСПРАВЛЕНИЕ ЗДЕСЬ: тоже используем ТЧ_Реализация и ТЧ_Договор
		Если Стр.ТЧ_Реализация.Пустая() Тогда
			МассивДоговоров.Добавить(Стр.ТЧ_Договор);
		КонецЕсли;
		
	КонецЦикла;
	ПараметрыЗадания.Вставить("МассивДоговоров", МассивДоговоров);
	
	Если МассивДоговоров.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Все документы уже созданы.");
		Возврат;
	КонецЕсли;

	// Запуск фонового задания
	АдресЗадания = ЗапуститьФоновоеЗаданиеНаСервере(ПараметрыЗадания);
	
	// Подключаем обработчик ожидания, который будет проверять статус задания
	ПодключитьОбработчикОжидания("ПроверитьСостояниеЗадания", 2); // каждые 2 секунды
	
	ПоказатьПользователюСообщение("Запущено создание документов..."); 
	
КонецПроцедуры 

&НаСервере  
Функция ЗапуститьФоновоеЗаданиеНаСервере(Параметры)
	
	ИмяМетода = "ВКМ_ОбслуживаниеСервер.ВыполнитьСоздание";
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Параметры);
	
	Задание = ФоновыеЗадания.Выполнить(ИмяМетода, МассивПараметров, Новый УникальныйИдентификатор, "Создание актов");
	
	// Помещаем ID задания во временное хранилище
	Адрес = ПоместитьВоВременноеХранилище(Задание.УникальныйИдентификатор, УникальныйИдентификатор);
	
	// Возвращаем этот адрес на Клиент
	Возврат Адрес; 
	
КонецФункции

&НаКлиенте
Процедура ПроверитьСостояниеЗадания()
	
	Если ЗаданиеВыполнено(АдресЗадания) Тогда
		ОтключитьОбработчикОжидания("ПроверитьСостояниеЗадания");
		ПоказатьПользователюСообщение("Создание документов завершено!");
		// Обновляем список, чтобы увидеть созданные документы
		Заполнить(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаданиеВыполнено(Адрес)
	
	ИдЗадания = ПолучитьИзВременногоХранилища(Адрес);
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдЗадания);
	
	Если Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
		Возврат Ложь;
	Иначе
		// Задание завершено (успешно или с ошибкой)
		Если Задание.ИнформацияОбОшибке <> Неопределено Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка в фоновом задании: " + Задание.ИнформацияОбОшибке.Описание;
			Сообщение.Сообщить();
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьПользователюСообщение(Текст)
	ПоказатьОповещениеПользователя("Массовое создание", , Текст);
КонецПроцедуры

