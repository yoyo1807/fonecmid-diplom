&НаСервереБезКонтекста
Функция ПолучитьДанныеСотрудника(Сотрудник, ДатаАктуальности)
	
	Результат = Новый Структура("Оклад, Процент", 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Условия.Оклад КАК Оклад,
		|	Условия.ПроцентОтРабот КАК Процент
		|ИЗ
		|	РегистрСведений.ВКМ_УсловияОплатыСотрудников.СрезПоследних(&Период, Сотрудник = &Сотрудник) КАК Условия";
	
	// Используем КонецДня, если нужно цеплять изменения внутри дня
	Запрос.УстановитьПараметр("Период", ДатаАктуальности); 
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат.Оклад = Выборка.Оклад;
		Результат.Процент = Выборка.Процент;
	КонецЕсли;
	
	Возврат Результат;	
КонецФункции

&НаКлиенте
Процедура НачисленияСотрудникПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Начисления.ТекущиеДанные;
	ЗаполнитьПоказателиСтроки(СтрокаТабличнойЧасти);
	
КонецПроцедуры

&НаКлиенте
Процедура НачисленияВидРасчетаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Начисления.ТекущиеДанные;
	ЗаполнитьПоказателиСтроки(СтрокаТабличнойЧасти);	
	
КонецПроцедуры     

&НаКлиенте
Процедура ЗаполнитьПоказателиСтроки(СтрокаТабличнойЧасти)
	
	Если СтрокаТабличнойЧасти = Неопределено 
		ИЛИ Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.Сотрудник) 
		ИЛИ Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидРасчета) Тогда
		Возврат;
	КонецЕсли;
	
	Данные = ПолучитьДанныеСотрудника(СтрокаТабличнойЧасти.Сотрудник, Объект.Дата);
	
	ОкладСсылка = ПредопределенноеЗначение("ПланВидовРасчета.ВКМ_ОсновныеНачисления.Оклад");
	// Внимание: проверьте имя предопределенного узла для Процента. 
	// Обычно процент — это Дополнительное начисление, но если вы добавили его в Основные:
	ПроцентСсылка = ПредопределенноеЗначение("ПланВидовРасчета.ВКМ_ОсновныеНачисления.Процент"); 
	
	Если СтрокаТабличнойЧасти.ВидРасчета = ОкладСсылка Тогда
		СтрокаТабличнойЧасти.РазмерОклад = Данные.Оклад; // Проверьте, что имя колонки именно "РазмерОклад"
	ИначеЕсли СтрокаТабличнойЧасти.ВидРасчета = ПроцентСсылка Тогда
		СтрокаТабличнойЧасти.РазмерОклад = Данные.Процент;
	КонецЕсли;
	
КонецПроцедуры

