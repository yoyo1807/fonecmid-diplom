Процедура ОбработкаПроведения(Отказ, Режим)
	
	// =====================================================================
	// 1. ПОЛУЧЕНИЕ ДАННЫХ ПО ДОГОВОРУ
	// =====================================================================
	
	Если Не ЗначениеЗаполнено(Договор) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не заполнен договор!";
		Сообщение.Поле = "Договор";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Договоры.ВидДоговора КАК ВидДоговора,
		|	Договоры.ВКМ_ДатаНачалаДоговора КАК ДатаНачала,
		|	Договоры.ВКМ_ДатаОкончанияДоговора КАК ДатаОкончания,
		|	ISNULL(Договоры.ВКМ_СтоимостьЧасаРаботы, 0) КАК СтоимостьЧаса
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК Договоры
		|ГДЕ
		|	Договоры.Ссылка = &Договор";
	
	Запрос.УстановитьПараметр("Договор", Договор);
	
	ВыборкаДоговора = Запрос.Выполнить().Выбрать();
	
	СтоимостьЧасаПоДоговору = 0; 	
	Если ВыборкаДоговора.Следующий() Тогда
		
		СтоимостьЧасаПоДоговору = ВыборкаДоговора.СтоимостьЧаса;
		
				Если ВыборкаДоговора.ВидДоговора <> Перечисления.ВидыДоговоровКонтрагентов.ВКМ_АбонентскоеОбслуживание Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Допустим только договор 'Абонентское обслуживание'!";
			Сообщение.Поле = "Договор";
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();
			Отказ = Истина;
		Иначе
			
			ДатаДокумента = НачалоДня(Дата);
			ДатаНачала = ?(ЗначениеЗаполнено(ВыборкаДоговора.ДатаНачала), НачалоДня(ВыборкаДоговора.ДатаНачала), Дата('00010101'));
			ДатаОкончания = ?(ЗначениеЗаполнено(ВыборкаДоговора.ДатаОкончания), НачалоДня(ВыборкаДоговора.ДатаОкончания), Дата('39991231'));
			
			Если ДатаДокумента < ДатаНачала ИЛИ ДатаДокумента > ДатаОкончания Тогда
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Дата документа не попадает в период действия договора!";
				Сообщение.Поле = "Дата";
				Сообщение.УстановитьДанные(ЭтотОбъект);
				Сообщение.Сообщить();
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;

	// =====================================================================
	// 2. ДВИЖЕНИЯ ПО РЕГИСТРУ "ВКМ_ВыполненныеКлиентуРаботы"
	// =====================================================================
	
	Движения.ВКМ_ВыполненныеКлиентуРаботы.Записывать = Истина;
	
	ВсегоЧасовКОплате = ВыполненныеРаботы.Итог("ЧасыКОплатеКлиенту");
	
	Если ВсегоЧасовКОплате > 0 Тогда
		Запись = Движения.ВКМ_ВыполненныеКлиентуРаботы.Добавить();
		Запись.Период = Дата;
		Запись.Клиент = Клиент;
		Запись.Договор = Договор;
		Запись.КоличествоЧасов = ВсегоЧасовКОплате;
		Запись.СуммаКОплате = ВсегоЧасовКОплате * СтоимостьЧасаПоДоговору; 
	КонецЕсли;

	// =====================================================================
	// 3. УВЕДОМЛЕНИЕ В ТЕЛЕГРАМ
	// =====================================================================
	
	ТекстДляБота = "✅ Проведено обслуживание клиента!" + Символы.ПС +
	" Клиент: " + Строка(Клиент) + Символы.ПС +
	" Договор: " + Строка(Договор) + Символы.ПС +
	" Специалист: " + Строка(Специалист) + Символы.ПС +
	"⏳ Всего часов к оплате: " + ВсегоЧасовКОплате;
	
	ЗаписьОчереди = Справочники.ВКМ_УведомленияТелеграмБоту.СоздатьЭлемент();
	ЗаписьОчереди.ТекстСообщения = ТекстДляБота;
	ЗаписьОчереди.Наименование = "Уведомление " + Номер; 
	ЗаписьОчереди.Записать(); 
	
	// =====================================================================
	// 4. ДВИЖЕНИЯ ПО РЕГИСТРУ "ВКМ_ВыполненныеСотрудникомРаботы"
	// =====================================================================
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ISNULL(Условия.ПроцентОтРабот, -1) КАК Процент
		|ИЗ
		|	РегистрСведений.ВКМ_УсловияОплатыСотрудников.СрезПоследних(&Период, Сотрудник = &Специалист) КАК Условия";
	
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("Специалист", Специалист);
	
	ВыборкаСотрудника = Запрос.Выполнить().Выбрать();
	
	ПроцентСотрудника = 0;
	
	Если ВыборкаСотрудника.Следующий() Тогда
		ПроцентСотрудника = ВыборкаСотрудника.Процент;
		
		Если ПроцентСотрудника = -1 Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не установлен процент оплаты для специалиста (нет записи в регистре)!";
			Сообщение.Сообщить();
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	Иначе

		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Нет данных об условиях оплаты сотрудника!";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Движения.ВКМ_ВыполненныеСотрудникомРаботы.Записывать = Истина;
	
	Для Каждого СтрокаТЧ Из ВыполненныеРаботы Цикл
		
		Движение = Движения.ВКМ_ВыполненныеСотрудникомРаботы.Добавить();
		Движение.Период = Дата;
		Движение.Сотрудник = Специалист;
		Движение.ЧасовКОплате = СтрокаТЧ.ФактическиПотраченоЧасов;
		Движение.СуммаКОплате = СтрокаТЧ.ФактическиПотраченоЧасов * СтоимостьЧасаПоДоговору * (ПроцентСотрудника / 100);
		
	КонецЦикла;

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ТекстУведомления = "";
	
	// 1. Если документ новый (первая запись)
	Если ЭтоНовый() Тогда
		ТекстУведомления = СтрШаблон(
			"Новая заявка на обслуживание!%1Клиент: %2%1Специалист: %3%1Дата: %4",
			Символы.ПС, 
			Клиент, 
			Специалист, 
			Формат(ДатаПроведенияРабот, "ДЛФ=D"));
			
	Иначе
		// 2. Если документ уже существует, проверяем изменения
		// Получаем "старые" значения из базы данных запросом
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Док.Специалист КАК Специалист,
			|	Док.ДатаПроведенияРабот КАК ДатаРабот,
			|	Док.ВремяНачалаРаботПлан КАК ВремяНачала,
			|	Док.ВремяОкончанияРаботПлан КАК ВремяОкончания
			|ИЗ
			|	Документ.ВКМ_ОбслуживаниеКлиентов КАК Док
			|ГДЕ
			|	Док.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			
			СписокИзменений = "";
			
			Если Выборка.Специалист <> Специалист Тогда
				СписокИзменений = СписокИзменений + СтрШаблон("%1Специалист: %2 -> %3", Символы.ПС, Выборка.Специалист, Специалист);
			КонецЕсли;
			
			Если Выборка.ДатаРабот <> ДатаПроведенияРабот Тогда
				СписокИзменений = СписокИзменений + СтрШаблон("%1Дата работ: %2 -> %3", Символы.ПС, Формат(Выборка.ДатаРабот, "ДЛФ=D"), Формат(ДатаПроведенияРабот, "ДЛФ=D"));
			КонецЕсли;
			
			Если Выборка.ВремяНачала <> ВремяНачалаРаботПлан Тогда
				СписокИзменений = СписокИзменений + СтрШаблон("%1Начало (план): %2 -> %3", Символы.ПС, Формат(Выборка.ВремяНачала, "ДЛФ=T"), Формат(ВремяНачалаРаботПлан, "ДЛФ=T"));
			КонецЕсли;
			
			Если Выборка.ВремяОкончания <> ВремяОкончанияРаботПлан Тогда
				СписокИзменений = СписокИзменений + СтрШаблон("%1Окончание (план): %2 -> %3", Символы.ПС, Формат(Выборка.ВремяОкончания, "ДЛФ=T"), Формат(ВремяОкончанияРаботПлан, "ДЛФ=T"));
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СписокИзменений) Тогда
				ТекстУведомления = "Изменились данные по заявке " + Номер + ":" + СписокИзменений;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстУведомления) Тогда
		ДополнительныеСвойства.Вставить("ВКМ_ТекстДляТелеграм", ТекстУведомления);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ВКМ_ТекстДляТелеграм") Тогда
		
		ТекстСообщения = ДополнительныеСвойства.ВКМ_ТекстДляТелеграм;
		
		НовоеУведомление = Справочники.ВКМ_УведомленияТелеграмБоту.СоздатьЭлемент();
		

		НовоеУведомление.ТекстСообщения = ТекстСообщения;
		
		НовоеУведомление.Наименование = "Уведомление по документу " + Номер;
		
		НовоеУведомление.Записать();
		
	КонецЕсли;
	
КонецПроцедуры

