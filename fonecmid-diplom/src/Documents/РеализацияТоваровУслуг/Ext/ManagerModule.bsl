// Гумерова ГР 10.03.2026 - Логика определения списка команд печати, предоставляемых этим объектом
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "АктВКМ_Финальный"; // Сменили ID для сброса кэша
	КомандаПечати.Представление = "Акт об оказанных услугах (ВКМ)";
	КомандаПечати.Порядок = 1;
	
КонецПроцедуры
 

// Гумерова ГР 10.03.2026 - Формируем печатные формы

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "АктВКМ_Финальный") Тогда
		
		ТабличныйДокумент = СформироватьПечатнуюФормуАкта(МассивОбъектов, ОбъектыПечати);
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм, 
			"АктВКМ_Финальный", 
			"Акт об оказанных услугах", 
			ТабличныйДокумент);
			
	КонецЕсли;

КонецПроцедуры

Функция СформироватьПечатнуюФормуАкта(МассивОбъектов, ОбъектыПечати)
	
ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РеализацияТоваровУслуг_Акт";
	
	// Используем простой ПолучитьМакет, если ПФ_MXL_Акт лежит в этом документе
	Макет = ПолучитьМакет("ПФ_MXL_Акт");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Реализация.Ссылка КАК Ссылка,
	|	Реализация.Номер КАК Номер,
	|	Реализация.Дата КАК Дата,
	|	Реализация.Организация КАК Организация,
	|	Реализация.Контрагент КАК Контрагент,
	|	Реализация.Договор КАК Договор,
	|	Реализация.Услуги.(
	|		Номенклатура КАК Номенклатура,
	|		Количество КАК Количество,
	|		Цена КАК Цена,
	|		Сумма КАК Сумма,
	|		НомерСтроки КАК НомерСтроки
	|	) КАК СоставУслуг
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Реализация
	|ГДЕ
	|	Реализация.Ссылка В(&МассивОбъектов)";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ВыборкаДокументов = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		// 1. Заголовок
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьЗаголовок.Параметры.Заполнить(ВыборкаДокументов);
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		// 2. Шапка
		ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
		ОбластьШапка.Параметры.Заполнить(ВыборкаДокументов);
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		// 3. ШапкаТаблицы
		ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
		
		// 4. Строки
		ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
		ВыборкаСтрок = ВыборкаДокументов.СоставУслуг.Выбрать();
		ИтогоСумма = 0;
		
		Пока ВыборкаСтрок.Следующий() Цикл
			ОбластьСтрока.Параметры.Заполнить(ВыборкаСтрок);
			// ВНИМАНИЕ: Если здесь будет ошибка, проверьте имя в макете!
			Попытка
				ОбластьСтрока.Параметры.НомерС = ВыборкаСтрок.НомерСтроки;
			Исключение
				// Если параметра "НомерС" нет в макете, просто пропустим
			КонецПопытки;
			
			ТабличныйДокумент.Вывести(ОбластьСтрока);
			ИтогоСумма = ИтогоСумма + ВыборкаСтрок.Сумма;
		КонецЦикла;
		
		// 5. Итого
		ОбластьИтого = Макет.ПолучитьОбласть("Итого");
		Попытка
			ОбластьИтого.Параметры.ВсегоСумма = ИтогоСумма;
		Исключение
		КонецПопытки;
		ТабличныйДокумент.Вывести(ОбластьИтого);
		
		// 6. Подвал
		ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
		ОбластьПодвал.Параметры.СуммаПрописью = ЧислоПрописью(ИтогоСумма, "L = ru_RU", "рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2");
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, 
			НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокументов.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;

КонецФункции


