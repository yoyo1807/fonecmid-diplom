// Эта процедура выполняется в фоновом режиме на сервере
Процедура ВыполнитьСоздание(Параметры) Экспорт
	
	Период = Параметры.Период; 
	
	МассивДоговоров = Параметры.МассивДоговоров;
	
	Для Каждого ДоговорRef Из МассивДоговоров Цикл
		
		// 1. Повторная проверка: вдруг кто-то уже создал документ, пока мы думали
		Если СуществуетДокументЗаПериод(ДоговорRef, Период) Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			
			// 2. Создание нового документа
			НовыйДокумент = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
			НовыйДокумент.Дата = КонецМесяца(Период); // Обычно акты делают концом месяца
			
			// 3. Стандартное заполнение (Заполнение шапки)
			// Имитируем ввод на основании или просто заполнение по умолчанию
			ДанныеЗаполнения = Новый Структура("Договор", ДоговорRef);
			НовыйДокумент.Заполнить(ДанныеЗаполнения);
			
			// Явное присвоение, если стандартное заполнение не справилось с шапкой
			НовыйДокумент.Договор = ДоговорRef;
			// Получаем организацию и контрагента из договора (через точку можно, т.к. мы на сервере и это не цикл по 1000 строк выборки, а единичная операция создания)
			НовыйДокумент.Контрагент = ДоговорRef.Владелец; // Владелец договора - это контрагент
			НовыйДокумент.Организация = ДоговорRef.Организация;
			
			// 4. Метод модуля объекта: ВыполнитьАвтозаполнение (из прошлого задания)
			НовыйДокумент.ВыполнитьАвтозаполнение();
			
			// Если документ получился пустым (сумма 0), возможно его не надо записывать?
			// Но по заданию про это не сказано. Записываем.
			
			// 5. Проверка заполнения (Стандартный механизм)
			Если НЕ НовыйДокумент.ПроверитьЗаполнение() Тогда
				// Если есть ошибки заполнения, документ не проводим, но можно записать просто так
				// Или пропустить. В рамках задачи лучше записать непроведенным.
				НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);
			Иначе
				// 6. Проведение
				НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			
		Исключение
			// Логируем ошибку в Журнал Регистрации, чтобы фоновое задание не падало целиком
			ЗаписьЖурналаРегистрации("ВКМ_МассовоеСоздание", УровеньЖурналаРегистрации.Ошибка, , ДоговорRef, ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;

КонецПроцедуры

// Вспомогательная функция для проверки дублей
Функция СуществуетДокументЗаПериод(Договор, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Реализация.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК Реализация
		|ГДЕ
		|	Реализация.Договор = &Договор
		|	И НАЧАЛОПЕРИОДА(Реализация.Дата, МЕСЯЦ) = НАЧАЛОПЕРИОДА(&Период, МЕСЯЦ)
		|	И НЕ Реализация.ПометкаУдаления";
		
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("Период", Период);
	
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
	
КонецФункции