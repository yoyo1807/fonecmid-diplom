Процедура ОтправитьСообщение(ТекстСообщения) Экспорт
	
	Токен = Константы.ВКМ_ТокенУправленияТелеграмБотом.Получить();
	IDГруппы = Константы.ВКМ_ИдентификаторГруппыДляОповещения.Получить();
	
	Если ПустаяСтрока(Токен) ИЛИ ПустаяСтрока(IDГруппы) Тогда
		ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Ошибка,,, 
			"Не заполнены настройки подключения (Токен или ID группы)");
		Возврат;
	КонецЕсли;
	
	Сервер = "api.telegram.org";
	Ресурс = "/bot" + Токен + "/sendMessage";
	
	// Подготовка JSON
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("chat_id", IDГруппы);
	СтруктураДанных.Вставить("text", ТекстСообщения);
	
	ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
	ТелоЗапроса = ЗаписьJSON.Закрыть();
	
	// HTTP Запрос
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	
	HTTPЗапрос = Новый HTTPЗапрос(Ресурс, Заголовки);
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	Попытка
		Соединение = Новый HTTPСоединение(Сервер, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL);
		Ответ = Соединение.ОтправитьДляОбработки(HTTPЗапрос);
		
		Если Ответ.КодСостояния <> 200 Тогда
			ТекстОшибки = Ответ.ПолучитьТелоКакСтроку();
			ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Ошибка,,, 
				"Ошибка API Телеграм (" + Ответ.КодСостояния + "): " + ТекстОшибки);
			ВызватьИсключение "Ошибка отправки в Телеграм: " + Ответ.КодСостояния;
		КонецЕсли;
		
	Исключение
		ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Ошибка,,, 
			"Ошибка соединения: " + ОписаниеОшибки());
		// Пробрасываем исключение, чтобы регламентное задание знало о сбое
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ОбработкаОчередиУведомлений() Экспорт
	
Запрос = Новый Запрос;
    Запрос.Текст = 
        "ВЫБРАТЬ ПЕРВЫЕ 10
        |	Увед.Ссылка КАК Ссылка,
        |	Увед.ТекстСообщения КАК Текст
        |ИЗ
        |	Справочник.ВКМ_УведомленияТелеграмБоту КАК Увед";
        // Убрали "ДЛЯ ИЗМЕНЕНИЯ" для теста, чтобы исключить проблемы с блокировками
        
    РезультатЗапроса = Запрос.Выполнить();
    
    // ПРОВЕРКА 1: Нашел ли запрос хоть что-то?
    Если РезультатЗапроса.Пустой() Тогда
        ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Предупреждение,,, 
            "Запрос вернул 0 записей. Справочник пуст или записи не подходят под условия.");
        Возврат;
    КонецЕсли;
    
    Выборка = РезультатЗапроса.Выбрать();
    
    Пока Выборка.Следующий() Цикл
        // ПРОВЕРКА 2: Какую именно запись мы взяли?
        ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Информация,,, 
            "Обработка записи: " + Выборка.Ссылка);
            
        Попытка
            ОтправитьСообщение(Выборка.Текст);
            
            УведОбъект = Выборка.Ссылка.ПолучитьОбъект();
            УведОбъект.Удалить();
            
            ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Информация,,, 
                "Запись успешно удалена.");
        Исключение
            ЗаписьЖурналаРегистрации("Телеграм", УровеньЖурналаРегистрации.Ошибка,,, 
                "Ошибка при обработке записи: " + ОписаниеОшибки());
        КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

